# Copy thành .env (KHÔNG commit .env — đã có trong .gitignore) để chạy local.
# Xem README.md mục "Secrets cần thiết" để biết cách lấy từng key.

GEMINI_API_KEY=
DEEPSEEK_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PRODUCTHUNT_TOKEN=

# Optional — chỉ cần nếu muốn tính năng tương tác real-time (Cloudflare
# Worker: nút "Hỏi sâu thêm", /refresh, hỏi follow-up tự do). Thiếu 3 biến
# này KHÔNG làm sập pipeline — main.py log warning và bỏ qua bước ghi KV.
# Xem README.md mục "Thiết lập tương tác real-time (Cloudflare Workers)".
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=

# DRY_RUN=true -> in console, không gọi Telegram API thật.
DRY_RUN=true
